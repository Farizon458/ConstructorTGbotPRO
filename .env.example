# Telegram constructor bot
BOT_TOKEN=YOUR_CONSTRUCTOR_BOT_TOKEN
BOT_USERNAME=YourConstructorBot

# Admins (comma-separated)
ADMIN_IDS=123456789,987654321

# Database
# PostgreSQL example: postgresql+psycopg2://user:pass@db:5432/constructor
# SQLite example: sqlite:///./dev.db
DATABASE_URL=postgresql+psycopg2://constructor:constructor@db:5432/constructor
SQL_ECHO=0

# Logs
LOG_DIR=./logs
LOG_LEVEL=INFO

# Payments (Telegram Invoice)
TELEGRAM_PROVIDER_TOKEN=TEST:1234567890
PAY_CURRENCY=RUB

# Default prices (can be changed via admin panel later)
VIP_PRICE_RUB=200
HOSTING_PRICE_RUB_MONTH=21.60
REF_PERCENT=10

# Links for "About"
LINK_ADMIN_CHAT=https://t.me/your_admin
LINK_SITE=https://example.com
LINK_DEV_CHANNEL=https://t.me/your_channel
LINK_SUPPORT=https://t.me/your_support

# Hosting billing policy (MVP)
# daily write-off in RUB; if 0 => disabled
HOSTING_DAILY_WRITE_OFF_RUB=0.72

# Scheduler
SCHEDULER_TIMEZONE=Asia/Dushanbe
